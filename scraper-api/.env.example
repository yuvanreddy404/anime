# Scraper API Configuration
# Copy this file to .env and customize

# AllAnime relay URL (default: https://relay-azure-six.vercel.app)
ALLANIME_RELAY=https://relay-azure-six.vercel.app

# GogoAnime base URL (default: https://gogoanime3.co)
GOGO_ANIME_URL=https://gogoanime3.co

# Allowed domains for proxy endpoints (comma-separated)
PROXY_ALLOWED_DOMAINS=allanime.to,allanime.day,allmanga.to,gogoanime3.co,nyaa.si

# Node environment
NODE_ENV=production
