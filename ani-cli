# SCRAPING

# extract the video links from response of embed urls, extract mp4 links form m3u8 lists
get_links() {
    case "$*" in
        *mp4upload*)
            episode_link=$(curl --max-time 10 -sLk "$*" -A "$agent" -e "$allanime_refr" | sed -nE 's|.*src: "([^"]*)"[[:space:]]*|Mp4Upload >\1|p')
            ;;
        *tools.fast4speed.rsvp*)
            episode_link=$(printf "%s\n" "Yt >${relay_v}$*")
            ;;
        *)
            response="$(curl -e "$allanime_refr" -s "https://${allanime_base}$*" -A "$agent")"
            episode_link="$(printf '%s' "$response" | sed 's|},{|\
        |g' | sed -nE 's|.*link":"([^"]*)".*"resolutionStr":"([^"]*)".*|\2 >\1|p;s|.*hls","url":"([^"]*)".*"hardsub_lang":"en-US".*|\1|p')"
            ;;
    esac

    case "$episode_link" in
        *repackager.wixmp.com*)
            extract_link=$(printf "%s" "$episode_link" | cut -d'>' -f2 | sed 's|repackager.wixmp.com/||g;s|\.urlset.*||g')
            for j in $(printf "%s" "$episode_link" | sed -nE 's|.*/,([^/]*),/mp4.*|\1|p' | sed 's|,|\
|g'); do
                printf "%s >%s\n" "$j" "$extract_link" | sed "s|,[^/]*|${j}|g"
            done | sort -nr
            ;;
        *master.m3u8*)
            # shellcheck disable=SC2154
            m3u8_refr=$(printf '%s' "$response" | sed -nE 's|.*Referer":"([^"]*)".*|\1|p') && printf '%s\n' "m3u8_refr >$m3u8_refr" >"$cache_dir/m3u8_refr"
            extract_link=$(printf "%s" "$episode_link" | head -1 | cut -d'>' -f2)
            relative_link=$(printf "%s" "$extract_link" | sed 's|[^/]*$||')
            m3u8_streams="$(curl -e "$m3u8_refr" -s "$extract_link" -A "$agent")"
            printf "%s" "$m3u8_streams" | grep -q "EXTM3U" && printf "%s" "$m3u8_streams" | sed 's|^#EXT-X-STREAM.*x||g; s|,.*|p|g; /^#/d; $!N; s|\n| >|;/EXT-X-I-FRAME/d' | sed "s|>|>${relative_link}|g" | sort -nr
            ;;
        *) [ -n "$episode_link" ] && printf "%s\n" "$episode_link" ;;
    esac
    # shellcheck disable=SC2154
    printf "\033[1;32m%s\033[0m Links Fetched\n" "$provider_name" 1>&2
}

# provider_extract_url and provider_fetch_streams are defined in providers/provider.sh
# provider_init logic is now handled by the modular provider system

select_quality() {
    # removing urls which have referrer to avoid playing on iSH and vlc (m3u8 streams don't get correct referrer)
    printf '%s' "$player_function" | cut -f1 -d" " | grep -qE '(android_vlc|iSH|vlc)' && links=$(printf '%s' "$links" | sed '/m3u8_refr >/d')
    printf '%s' "$player_function" | cut -f1 -d" " | grep -qE '(android_vlc|iSH)' && links=$(printf '%s' "$links" | sed '/Yt >/d')
    case "$1" in
        best) result=$(printf "%s" "$links" | head -n1) ;;
        worst) result=$(printf "%s" "$links" | grep -E '^[0-9]{3,4}' | tail -n1) ;;
        *) result=$(printf "%s" "$links" | grep -m 1 "$1") ;;
    esac
    [ -z "$result" ] && printf "Specified quality not found, defaulting to best\n" 1>&2 && result=$(printf "%s" "$links" | head -n1)

    # add refr for m3u8 and refr flag for yt
    case "$result" in
        *mp4upload*)
            refr_flag="--referrer=https://www.mp4upload.com"
            ;;
        *sharepoint*)
            unset refr_flag
            ;;
        *)
            refr_flag="--referrer=$allanime_refr"
            ;;
    esac

    episode=$(printf "%s" "$result" | cut -d'>' -f2)
}

fetch_nyaa_streams() {
    search_title="$(printf "%s" "$allanime_title" | sed 's/ vs .*//;s/ : .*//;s/ - .*//;s/ *(.*//' | xargs)"
    query="$(printf "%s" "$search_title" | tr ' ' '+' | sed 's/[^a-zA-Z0-9+._~-]/_/g')"

    resp=$(curl -s --max-time 15 "https://scraper-api-puce.vercel.app/api/nyaa?q=$query" -A "$agent")
    [ -z "$resp" ] && return 1

    torrent_list=$(printf "%s" "$resp" | python3 -c '
import json,sys
d=json.load(sys.stdin)
r=d.get("results",[])
if not r:
    sys.exit(1)
r.sort(key=lambda x:(-x.get("seeders",0),-x.get("leechers",0)))
for x in r[:40]:
    sys.stdout.write("%5s SE %5s LE %10s  %s\n" % (x.get("seeders",0),x.get("leechers",0),x.get("size","?"),x.get("title","?")))
    sys.stdout.write("magnet:%s\n" % x.get("magnet",""))
') || return 1
    [ -z "$torrent_list" ] && return 1
    NYAA_TORRENTS="$torrent_list"
}

select_nyaa_torrent() {
    [ -z "$NYAA_TORRENTS" ] && fetch_nyaa_streams || true
    [ -z "$NYAA_TORRENTS" ] && return 1

    # Build a clean menu: line number + title only (hide magnet lines)
    menu=""
    idx=1
    while IFS= read -r line; do
        case "$line" in
            magnet:*) ;;
            *) menu="$menu$idx	$line
" ; idx=$((idx + 1)) ;;
        esac
    done <<EOF
$NYAA_TORRENTS
EOF

    [ -z "$menu" ] && return 1

    if command -v fzf >/dev/null && [ "$use_external_menu" = "0" ]; then
        selection="$(printf "%s" "$menu" | fzf --reverse --prompt "Select torrent: ")"
    else
        printf "%s\n" "Available torrents:"
        printf "%s\n" "------------------------------------------------"
        printf "%s" "$menu" | head -30
        printf "%s\n" "------------------------------------------------"
        printf "Select torrent (1-30): "
        read -r choice
        [ -z "$choice" ] && return 1
        selection=$(printf "%s" "$menu" | sed -n "${choice}p")
        [ -z "$selection" ] && return 1
    fi

    [ -z "$selection" ] && return 1

    # Find the selected title in the menu and get its index
    sel_idx=$(printf "%s" "$menu" | grep -nF "$selection" | head -1 | cut -d: -f1)
    [ -z "$sel_idx" ] && return 1

    # Get the magnet from NYAA_TORRENTS: title is at (sel_idx*2-1), magnet is at (sel_idx*2)
    mag_line=$((sel_idx * 2))
    episode=$(printf "%s" "$NYAA_TORRENTS" | sed -n "${mag_line}p" | sed 's/^magnet://')

    [ -z "$episode" ] && return 1

    return 0
}

process_response() {
    if ! printf '%s' "$1" | grep -q '"tobeparsed"'; then
        printf '%s' "$1"
        return 0
    fi

    tmp="$(mktemp)"
    printf '%s' "$1" | sed -nE 's|.*"tobeparsed":"([^"]*)".*|\1|p' | base64 -d >"$tmp"
    file_size="$(wc -c <"$tmp")"
    iv="$(dd if="$tmp" bs=1 skip=1 count=12 2>/dev/null | od -A n -t x1 | tr -d ' \n')"
    ctr="${iv}00000002"
    ct_len=$((file_size - 13 - 16))
    dd if="$tmp" bs=1 skip=13 count="$ct_len" 2>/dev/null | openssl enc -d -aes-256-ctr -K "$allanime_key" -iv "$ctr" -nosalt -nopad 2>/dev/null
    rm -f "$tmp"
}

b64url_to_hex() {
    _len=$(printf '%s' "$1" | wc -c | tr -d ' ')
    _mod=$((_len % 4))
    case $_mod in
        2) _pad="==" ;;
        3) _pad="=" ;;
        *) _pad="" ;;
    esac
    printf '%s%s' "$1" "$_pad" | tr -- '-_' '+/' | base64 -d | od -A n -t x1 | tr -d ' \n'
}

get_filemoon_links() {
    response="$(curl -e "$allanime_refr" -s "https://${allanime_base}$1" -A "$agent")"
    _fm_json="$(printf '%s' "$response" | tr -d '\n ' | tr ',' '\n')"
    iv="$(printf '%s' "$_fm_json" | sed -nE 's|^"iv":"([^"]*)"$|\1|p')"
    payload="$(printf '%s' "$_fm_json" | sed -nE 's|^"payload":"([^"]*)"$|\1|p')"
    kp1="$(printf '%s' "$_fm_json" | sed -nE 's|^"key_parts":\["([^"]*)"$|\1|p')"
    kp2="$(printf '%s' "$_fm_json" | sed -nE 's|^"([A-Za-z0-9_-]+)"\]$|\1|p' | head -1)"
    _kp1_hex="$(b64url_to_hex "$kp1")"
    _kp2_hex="$(b64url_to_hex "$kp2")"
    key_hex="$_kp1_hex$_kp2_hex"
    iv_hex="$(b64url_to_hex "$iv")00000002"
    tmp="$(mktemp)"
    _fm_len=$(printf '%s' "$payload" | wc -c | tr -d ' ')
    _fm_mod=$((_fm_len % 4))
    case $_fm_mod in
        2) _fm_pad="==" ;;
        3) _fm_pad="=" ;;
        *) _fm_pad="" ;;
    esac
    printf '%s%s' "$payload" "$_fm_pad" | tr -- '-_' '+/' | base64 -d >"$tmp"
    ct_len=$(($(wc -c <"$tmp") - 16))
    plain="$(dd if="$tmp" bs=1 count="$ct_len" 2>/dev/null | openssl enc -d -aes-256-ctr -K "$key_hex" -iv "$iv_hex" -nosalt -nopad 2>/dev/null)"
    rm -f "$tmp"
    printf '%s' "$plain" | tr '{}[]' '\n' |
        sed -nE 's|.*"url":"([^"]*)".*"height":([0-9]+).*|\2 >\1|p;s|.*"height":([0-9]+).*"url":"([^"]*)".*|\1 >\2|p' |
        sed 's|\\u0026|\&|g;s|\\u003D|=|g' | sort -rn
    printf "\033[1;32m%s\033[0m Links Fetched\n" "Filemoon" 1>&2
}

# Gets embed urls, collects direct links via provider modules,
